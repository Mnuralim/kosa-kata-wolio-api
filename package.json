{
  "name": "kosa-kata-wolio-api",
  "version": "1.0.0",
  "description": "API untuk aplikasi Kosa Kata Wolio - kamus bahasa Wolio",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "postinstall": "bunx --bun prisma generate",
    "dev": "bun --hot index.ts",
    "start": "bun index.ts",
    "seed": "bun run prisma/seed.ts",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:push": "bunx --bun prisma db push",
    "db:studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mariadb": "^3.5.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.7.0",
    "typescript": "^5.9.3"
  }
}
